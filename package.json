{
  "name": "storycap-run",
  "version": "0.1.0",
  "description": "CLI for capturing Storybook screenshots via storycap-testrun",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ypresto/storycap-run.git"
  },
  "keywords": [
    "storybook",
    "screenshot",
    "storycap",
    "vitest",
    "visual-testing"
  ],
  "bin": {
    "storycap-run": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsdown"
  },
  "dependencies": {
    "@storycap-testrun/browser": "^2.0.0",
    "cac": "^7.0.0"
  },
  "peerDependencies": {
    "@storybook/addon-vitest": ">=8.0.0",
    "vitest": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@vitest/browser": "^3.2.4",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
